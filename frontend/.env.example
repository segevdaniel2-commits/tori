# Vite env vars — copy to .env and fill in values

# Google Places Autocomplete (optional)
# Get a key at: https://console.cloud.google.com/ — enable "Places API"
VITE_GOOGLE_PLACES_API_KEY=

# Stripe publishable key (required for billing)
# Get from: https://dashboard.stripe.com/apikeys  (use pk_test_... for test mode)
VITE_STRIPE_PUBLISHABLE_KEY=
