PORT=3001
CLIENT_URL=http://localhost:3000

# Database
DB_PATH=./tori.db

# JWT - REQUIRED: at least 32 random characters
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Groq AI
GROQ_API_KEY=

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Set this to a random string in Meta Developer Console > Webhooks
WHATSAPP_VERIFY_TOKEN=REPLACE_WITH_RANDOM_VERIFY_TOKEN
# Meta App Secret (Settings > Basic in Meta App Dashboard) — used to verify webhook signatures
WHATSAPP_APP_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# Resend (Email)
RESEND_API_KEY=
FROM_EMAIL=noreply@tori.com

# App
NODE_ENV=development
CLIENT_URL=http://localhost:3000
